# Synthetic native netrc conformance fixture
machine example.com login first-user password obsolete-secret
machine EXAMPLE.com login "last user" account billing-account password "synthetic secret # 2" # final duplicate wins
machine api.example.com:8443 user port-user password escaped\ secret
machine bücher.example login idna-user password unicode-secret
machine empty.example login "" account "" password ""

macdef init
echo machine ignored.example login ignored password never-parsed
echo "quotes and # are opaque macro text"

default login fallback-user password fallback-secret
